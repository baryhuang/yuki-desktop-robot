# DigitalOcean Serverless Inference. Keep the real token out of Git.
DIGITALOCEAN_TOKEN=
YUKI_DO_CHAT_MODEL=llama3.3-70b-instruct
YUKI_DO_TTS_MODEL=qwen3-tts-voicedesign
YUKI_TTS_VOICE=alloy

# Speech-to-text is a private Whisper service in docker-compose.yml. DigitalOcean
# Serverless Inference currently has no transcription endpoint.
YUKI_STT_BASE_URL=http://whisper:8000/v1
YUKI_STT_API_KEY=
YUKI_STT_MODEL=base

# First-run model download for the private STT service. `base` is multilingual
# and suitable for a CPU-only DigitalOcean Droplet demo.
WHISPER_MODEL=base
WHISPER_COMPUTE_TYPE=int8

# Network settings. Use a random value when exposing the gateway outside a
# trusted LAN, then compile the same value into the device setting.
YUKI_GATEWAY_TOKEN=
PORT=8787
