# Realtime production backend. The gateway remains on the DigitalOcean CPU
# Droplet; Vertex AI replaces the serial Whisper -> chat -> TTS path.
YUKI_VOICE_BACKEND=gemini-live
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-west1
YUKI_GEMINI_MODEL=gemini-live-2.5-flash-native-audio
YUKI_GEMINI_VOICE=Leda
YUKI_GEMINI_VISION_MODEL=gemini-2.5-flash
YUKI_ENABLE_GOOGLE_SEARCH=true

# Temporary DigitalOcean fallback. Keep the real token out of Git.
DIGITALOCEAN_TOKEN=
YUKI_DO_CHAT_MODEL=openai-gpt-oss-20b
YUKI_DO_TTS_MODEL=qwen3-tts-voicedesign
YUKI_TTS_VOICE=alloy

# These STT settings are used only with YUKI_VOICE_BACKEND=digitalocean.
YUKI_STT_BASE_URL=http://whisper:8000/v1
YUKI_STT_API_KEY=
YUKI_STT_MODEL=small

# First-run model download for the optional private STT fallback service.
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8

# Network settings. Use a random value when exposing the gateway outside a
# trusted LAN, then compile the same value into the device setting.
YUKI_GATEWAY_TOKEN=
YUKI_GATEWAY_HOST=yuki.example.com
# Override only when camera uploads use a different public endpoint.
# YUKI_VISION_URL=https://yuki.example.com/vision
PORT=8787
