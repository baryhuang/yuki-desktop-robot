# DigitalOcean Serverless Inference. Keep the real token out of Git.
DIGITALOCEAN_TOKEN=
YUKI_DO_CHAT_MODEL=llama3.3-70b-instruct
YUKI_DO_TTS_MODEL=qwen3-tts-voicedesign
YUKI_TTS_VOICE=alloy

# OpenAI-compatible speech-to-text provider. DigitalOcean Serverless Inference
# currently has no documented transcription endpoint, so this is deliberately
# separate from the DigitalOcean key.
YUKI_STT_BASE_URL=https://api.openai.com/v1
YUKI_STT_API_KEY=
YUKI_STT_MODEL=gpt-4o-mini-transcribe

# Network settings. Use a random value when exposing the gateway outside a
# trusted LAN, then compile the same value into the device setting.
YUKI_GATEWAY_TOKEN=
PORT=8787
