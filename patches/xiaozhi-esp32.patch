+void Application::StartProactiveConversation(const std::string& prompt) {
+    Schedule([this, prompt]() {
+        if (!protocol_ || GetDeviceState() != kDeviceStateIdle) {
+            ESP_LOGW(TAG, "Ignoring proactive conversation while unavailable");
+            return;
+        }
+
+        SetDeviceState(kDeviceStateConnecting);
+        Schedule([this, prompt]() {
+            ContinueProactiveConversation(prompt);
+        });
+    });
+}
+
+void Application::ContinueProactiveConversation(const std::string& prompt) {
+    if (!protocol_ || GetDeviceState() != kDeviceStateConnecting) {
+        return;
+    }
+    if (!protocol_->IsAudioChannelOpened() && !protocol_->OpenAudioChannel()) {
+        SetDeviceState(kDeviceStateIdle);
+        return;
+    }
+
+    ESP_LOGI(TAG, "Starting proactive conversation");
+    protocol_->SendWakeWordDetected(prompt);
+    SetListeningMode(GetDefaultListeningMode());
+}
